# Each entry: {"bcookie": "", "bscookie": "", "JSESSIONID": "", "li_at": ""}. Extra keys are included in Cookie header.
COOKIE_JSON_PATH = os.path.join(os.path.dirname(os.path.abspath(__file__)), "LinkedinCookie.json")

def _load_profiles():
    with open(COOKIE_JSON_PATH, "r", encoding="utf-8") as f:
        entries = json.load(f)
    profiles = []
    for item in entries:
        if "JSESSIONID" not in item:
            raise ValueError("LinkedinCookie.json: each entry must have 'JSESSIONID'")
        cookie_parts = [f"{k}={v}" for k, v in item.items()]
        cookie_str = "; ".join(cookie_parts)
        profiles.append({
            "cookie": cookie_str,
            "csrf_token": item["JSESSIONID"],
        })
    return profiles

